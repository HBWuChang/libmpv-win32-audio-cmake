#!/bin/bash
export O_PATH="$PATH"

# Find MinGW cmake: prefer toolchain, then system locations
if [ -x "@MINGW_INSTALL_PREFIX@/bin/@TARGET_ARCH@-cmake" ]; then
    mingw_cmake_dir="@MINGW_INSTALL_PREFIX@/bin"
elif [ -x "@MINGW_INSTALL_PREFIX@/bin/cmake" ]; then
    mingw_cmake_dir="@MINGW_INSTALL_PREFIX@/bin"
elif [ -x "/usr/bin/@TARGET_ARCH@-cmake" ]; then
    mingw_cmake_dir="/usr/bin"
elif [ -x "/usr/bin/cmake" ]; then
    mingw_cmake_dir="/usr/bin"
elif [ -x "/usr/local/bin/cmake" ]; then
    mingw_cmake_dir="/usr/local/bin"
else
    mingw_cmake_dir=""
fi

export PATH="${mingw_cmake_dir}:@CMAKE_INSTALL_PREFIX@/bin:@RUSTUP_LOCATION@/../cargo/bin:$PATH"
export PKG_CONFIG="pkgconf --static"
export PKG_CONFIG_LIBDIR="@MINGW_INSTALL_PREFIX@/lib/pkgconfig"
export RUSTUP_HOME="@RUSTUP_LOCATION@/../rustup"
export CARGO_HOME="@RUSTUP_LOCATION@/../cargo"
export LDL_PRELOAD="@MALLOAD"
export CCACHE_DIR="@MINGW_INSTALL_PREFIX@/ccache"
export LLVMPROFILE_FILE="/dev/null"

# disable profraw output by default, ensure that only clang and lld can explicitly enable profraw output by wrapper

eval $*
